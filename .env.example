# FairwayIQ — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. All secrets also go into Vercel env vars.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (used by Supabase Auth provider) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Maps JavaScript API ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- OpenAI (AI advice — default model: gpt-4o; override via OPENAI_MODEL) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# --- Flash Score API (outbound — shared secret for the downstream Flash Score app) ---
# Generate any strong random string. Same value goes into Flash Score's env.
FLASH_SCORE_API_KEY=